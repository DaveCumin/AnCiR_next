# Copy to app/.env and edit. Loaded automatically by `npm run app` (Node --env-file).
# All optional — these are the defaults.

# Where the AnCiR GUI is served (the ?loadFromURL= target). Must be running.
ANCIR_BASE_URL=http://localhost:5173

# Backend bind address. APP_HOST=0.0.0.0 enables "public" mode: the SSRF guard on the
# BYO baseUrl kicks in (https-only, blocks private/loopback, allowlist of providers).
APP_PORT=5273
APP_HOST=127.0.0.1

# Hardening knobs (all optional).
# LOG_LEVEL=info                      # pino level (debug|info|warn|error)
# BUILD_RATE_MAX=10                   # builds per window per IP (DoS floor)
# BUILD_RATE_WINDOW_MS=60000          # rate-limit window
# TRUST_PROXY=1                       # proxy hops in front (Cloudflare tunnel = 1)
# SESSION_TTL_MS=3600000              # how long built sessions stay fetchable
# SSRF relaxations for public mode (APP_HOST=0.0.0.0):
# ALLOW_LOCAL_LLM=1                   # permit localhost/private baseUrl (dev only!)
# ALLOW_CUSTOM_LLM_ENDPOINTS=1        # allow any https host (skip provider allowlist)
# LLM_EXTRA_HOSTS=host1,host2         # add hosts to the allowlist

# OPTIONAL server-default model. Users normally bring their own via the page's
# "Model settings" panel (sent per request; never stored). These OPENAI_* vars are
# only a fallback for requests that don't include a model config. Leave them unset to
# make the app pure bring-your-own (requests without a config get the scripted demo).
# Any OpenAI-compatible endpoint works and the model MUST support tool/function calling.
# Uncomment ONE provider block:

# --- OpenAI ---
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# MODEL=gpt-4o-mini

# --- Groq (fast, but per-minute token limits on the free tier) ---
# OPENAI_API_KEY=gsk_...
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# MODEL=llama-3.3-70b-versatile

# --- NVIDIA NIM (pick a model whose page lists function-calling support) ---
# OPENAI_API_KEY=nvapi-...
# OPENAI_BASE_URL=https://integrate.api.nvidia.com/v1
# MODEL=meta/llama-3.3-70b-instruct

# --- Ollama (local, no key, no rate limits; needs a big context — see README) ---
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# MODEL=llama3.1
