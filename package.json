{
	"name": "ancir-next",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "node src/lib/utils/generateBuild.js && vite build",
		"postbuild": "node --env-file=.env -e \"const {execSync}=require('child_process'); const cmd=process.env.DEPLOY_COMMAND; if(cmd){console.log('🚀 Uploading to FTP...'); execSync(cmd,{stdio:'inherit',cwd:process.cwd()}); console.log('✅ FTP upload completed!');} else {console.warn('⚠️ No DEPLOY_COMMAND in .env');}\" || echo '⚠️ FTP upload skipped.'",
		"testbuild": "vitest run && node src/lib/utils/generateBuild.js && vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./jsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check . && eslint .",
		"test": "vitest",
		"test:ui": "vitest --ui",
		"test:coverage": "vitest run --coverage",
		"test:e2e": "playwright test",
		"test:all": "npm test && npm run test:e2e"
	},
	"devDependencies": {
		"@eslint/compat": "^1.4.1",
		"@eslint/js": "^9.39.2",
		"@playwright/test": "^1.59.1",
		"@sveltejs/adapter-auto": "^4.0.0",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.49.2",
		"@sveltejs/vite-plugin-svelte": "^5.1.1",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.13.1",
		"globals": "^16.5.0",
		"happy-dom": "^20.8.9",
		"prettier": "^3.7.4",
		"prettier-plugin-svelte": "^3.4.1",
		"svelte": "^5.46.1",
		"svelte-check": "^4.3.5",
		"typescript": "^5.9.3",
		"vite": "^6.4.1",
		"vitest": "^4.1.2"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	},
	"dependencies": {
		"@fortawesome/free-solid-svg-icons": "^6.7.2",
		"@fortawesome/svelte-fontawesome": "^0.2.4",
		"d3-array": "^3.2.4",
		"d3-axis": "^3.0.0",
		"d3-ease": "^3.0.1",
		"d3-quadtree": "^3.0.1",
		"d3-scale": "^4.0.2",
		"d3-selection": "^3.0.0",
		"d3-shape": "^3.2.0",
		"d3-time-format": "^4.1.0",
		"d3-transition": "^3.0.1",
		"fast-json-patch": "^3.1.1",
		"fflate": "^0.8.2",
		"luxon": "^3.7.2",
		"papaparse": "^5.5.3",
		"rollup-plugin-visualizer": "^6.0.5"
	}
}
